<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Complaint History</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <header class="header">
      <div class="brand">
        <div class="logo">EG</div>
        <div>
          <div class="site-title">Complaint History</div>
          <div style="font-size:13px;color:var(--muted)">Track your past submissions</div>
        </div>
      </div>
      <div class="actions">
        <a href="/student-dashboard.html" class="btn secondary">Dashboard</a>
      </div>
    </header>

    <div class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Ref ID</th>
            <th>Title</th>
            <th>Category</th>
            <th>Submitted</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% complaints.forEach((c, i) => { %>
            <tr>
              <td><%= c._id %></td>
              <td><%= c.title %></td>
              <td><%= c.category %></td>
              <td><%= new Date(c.createdAt).toLocaleDateString() %></td>
              <td>
                <% if (c.status === 'Resolved') { %>
                  <span class="badge resolved"><%= c.status %></span>
                <% } else if (c.status === 'In Process') { %>
                  <span class="badge inprocess"><%= c.status %></span>
                <% } else { %>
                  <span class="badge pending"><%= c.status %></span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
