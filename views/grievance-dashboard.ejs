<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Grievance Cell Dashboard</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <header class="header">
      <div class="brand">
        <div class="logo">GC</div>
        <div>
          <div class="site-title">Grievance Cell</div>
          <div style="font-size:13px;color:var(--muted)">Handle escalated complaints</div>
        </div>
      </div>
      <div class="actions">
        <a href="/logout" class="btn secondary">Logout</a>
      </div>
    </header>

    <div class="card">
      <h3>Escalated Complaints (In Process)</h3>
      <table class="table">
        <thead>
          <tr>
            <th>Ref</th>
            <th>Title</th>
            <th>Category</th>
            <th>Student</th>
            <th>Description</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% complaints.forEach(c => { %>
            <tr>
              <td><%= c._id %></td>
              <td><%= c.title %></td>
              <td><%= c.category %></td>
              <td><%= c.anonymous ? "Anonymous" : c.student?.name %></td>
              <td><%= c.description %></td>
              <td><span class="badge inprocess"><%= c.status %></span></td>
              <td>
                <form method="POST" action="/grievance/resolve">
                  <input type="hidden" name="id" value="<%= c._id %>">
                  <button class="btn" type="submit">Mark Resolved</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
